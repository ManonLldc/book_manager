<div class="container">
  <h1>Détail du livre</h1>

  <div class="book-detail-card">
    <p>
      <strong>Titre :</strong>
      <%= @book.title %>
    </p>

    <p>
      <strong>Auteur :</strong>
      <%= @book.author %>
    </p>

    <p>
      <strong>Statut :</strong>
      <% case @book.status %>
      <% when "À lire" %>
        <span class="badge badge-a-lire">À lire</span>
      <% when "En cours" %>
        <span class="badge badge-en-cours">En cours</span>
      <% when "Lu" %>
        <span class="badge badge-lu">Lu</span>
      <% end %>
    </p>
  </div>

  <br>

  <%= link_to "← Retour", books_path, class: "btn" %>
  <%= link_to "Modifier", edit_book_path(@book), class: "btn" %>
</div>